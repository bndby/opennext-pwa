        "@types/react-dom": "^19.2.3",
        "eslint": "^9.39.4",
        "eslint-config-next": "^16.2.10",
        "postcss": "^8.5.16",
        "prettier": "^3.9.4",
        "typescript": "^6.0.3",
        "wrangler": "^4.107.0",
        "zod": "^4.4.3"
